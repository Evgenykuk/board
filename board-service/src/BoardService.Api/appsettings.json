{
  "ConnectionStrings": {
    "BoardDb": "Host=board_db;Port=5432;Database=board;Username=admin;Password=password"
  },
  "Kafka": {
    "BootstrapServers": "kafka:9092",
    "GroupId": "board-consumer-group",
    "AutoOffsetReset": "latest"
  },
  "GroundControl": {
    "BaseUrl": "http://ground:8000"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "WriteTo": [
      { "Name": "Console" }
    ],
    "MinimumLevel": "Information"
  }
}
